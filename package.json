{
  "name": "openclaw-desktop",
  "version": "1.0.0",
  "description": "OpenClaw 桌面版 - 便携式 AI 助手客户端，零配置开箱即用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "openclaw",
    "桌面版",
    "便携式",
    "沙箱",
    "AI助手",
    "人工智能"
  ],
  "author": "OpenClaw Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "extract-zip": "^2.0.1"
  },
  "build": {
    "appId": "com.openclaw.desktop",
    "productName": "OpenClaw 桌面版",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}